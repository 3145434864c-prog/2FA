{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatbotInventario Contrato v1",
  "type": "object",
  "properties": {
    "accion": {
      "type": "string",
      "enum": ["stock_producto", "stock_bajo", "movimientos_recientes", "buscar_producto", "valor_inventario"],
      "description": "Acción white-list exacta"
    },
    "parametros": {
      "type": "object",
      "properties": {
        "nombre_producto": {
          "type": ["string", "null"],
          "description": "Nombre parcial/exacto o null",
          "maxLength": 100
        }
      },
      "additionalProperties": false,
      "minProperties": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": ">=0.7 para ejecutar"
    }
  },
  "required": ["accion", "parametros", "confidence"],
  "additionalProperties": false
}

